# App
SECRET_KEY=your_long_random_secret_key
APP_USERNAME=admin
APP_PASSWORD=your_secure_password
TOTP_SECRET=your_base32_totp_secret

# WireGuard server (shown in client .conf files)
SERVER_PUBLIC_KEY=your_wireguard_server_public_key
SERVER_IP=your_vps_or_router_ip
SERVER_PORT=51820
CLIENT_DNS=192.168.88.1

# MikroTik RouterOS API
MT_HOST=your_mikrotik_ip
MT_USERNAME=api
MT_PASSWORD=your_api_user_password
MT_PORT=8728
MT_WIREGUARD_INTERFACE=WireGuard1

# Security (optional — these are the defaults)
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
SESSION_TIMEOUT_MIN=30
IP_WHITELIST=

# Notifications
WEEKLY_DIGEST_DAY=monday
